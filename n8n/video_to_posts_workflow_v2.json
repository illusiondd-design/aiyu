    },
    {
      "parameters": {
        "functionCode": "const raw = $json.stdout || $json.data || ''; return [{ json: JSON.parse(raw) }];"
      },
      "id": "parse_config",
      "name": "Parse Config",
      "type": "n8n-nodes-base.function",
      "typeVersion": 1,
      "position": [620, 300]
    },
    {
      "parameters": {
        "command": "cat \"{{$json.transcript_path}}\""
      },
